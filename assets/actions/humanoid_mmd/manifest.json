{
  "schema_version": "1.0",
  "id": "actions_humanoid_mmd",
  "version": 1,
  "type": "action_library",
  "blend": "compiled/humanoid_actions.blend",
  "reference_model": "source/reference.pmx",
  "import_scale": 0.08,
  "default_fallback": "idle",
  "actions": {
    "idle": {"action": "MMD_Idle", "source": "source/idle.vmd", "track": "base", "loop": true},
    "walk": {"action": "MMD_Walk", "source": "source/walk.vmd", "track": "base", "loop": true, "root_motion": false},
    "walk_fast": {"fallback": "walk"},
    "run": {"action": "MMD_Run", "source": "source/run.vmd", "track": "base", "loop": true, "root_motion": false},
    "turn_left": {"action": "MMD_TurnLeft", "source": "source/turn_left.vmd", "track": "base"},
    "turn_right": {"action": "MMD_TurnRight", "source": "source/turn_right.vmd", "track": "base"},
    "sit_down": {"action": "MMD_SitDown", "source": "source/sit_down.vmd", "track": "base"},
    "stand_up": {"action": "MMD_StandUp", "source": "source/stand_up.vmd", "track": "base"},
    "talk": {"action": "MMD_Talk", "source": "source/talk.vmd", "track": "upper", "loop": true},
    "listen": {"action": "MMD_Listen", "source": "source/listen.vmd", "track": "upper", "loop": true},
    "point": {"action": "MMD_Point", "source": "source/point.vmd", "track": "upper"},
    "wave": {"action": "MMD_Wave", "source": "source/wave.vmd", "track": "upper", "loop": true},
    "look_around": {"action": "MMD_LookAround", "source": "source/look_around.vmd", "track": "upper"},
    "surprised": {"action": "MMD_Surprised", "source": "source/surprised.vmd", "track": "upper"},
    "angry": {"action": "MMD_Angry", "source": "source/angry.vmd", "track": "upper", "loop": true},
    "sad": {"action": "MMD_Sad", "source": "source/sad.vmd", "track": "upper", "loop": true},
    "punch": {"action": "MMD_Punch", "source": "source/punch.vmd", "track": "base"},
    "get_hit": {"action": "MMD_GetHit", "source": "source/get_hit.vmd", "track": "additive", "blend_type": "ADD"},
    "fall_down": {"action": "MMD_Fall", "source": "source/fall_down.vmd", "track": "base"},
    "get_up": {"action": "MMD_GetUp", "source": "source/get_up.vmd", "track": "base"},
    "talk_happy": {"fallback": "talk"},
    "talk_angry": {"fallback": "angry"},
    "talk_sad": {"fallback": "sad"},
    "walk_slow": {"fallback": "walk"},
    "sprint": {"fallback": "run"}
  }
}
