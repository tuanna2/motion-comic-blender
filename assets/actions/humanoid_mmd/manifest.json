{
  "schema_version": "1.0",
  "id": "actions_humanoid_mmd",
  "version": 1,
  "type": "action_library",
  "blend": "compiled/humanoid_actions.blend",
  "reference_model": "../../characters/mmd_demo/source/character.pmd",
  "import_scale": 0.08,
  "default_fallback": "idle",
  "sample_motion_source": "Gengorou-C/KAIMyEntity-C requiredFiles release",
  "actions": {
    "idle": {"action": "MMD_Idle", "source": "source/idle.vmd", "track": "base", "loop": true},
    "walk": {"action": "MMD_Walk", "source": "source/walk.vmd", "track": "base", "loop": true, "root_motion": false},
    "run": {"action": "MMD_Run", "source": "source/run.vmd", "track": "base", "loop": true, "root_motion": false},
    "sneak": {"action": "MMD_Sneak", "source": "source/sneak.vmd", "track": "base", "loop": true, "root_motion": false},
    "crawl": {"action": "MMD_Crawl", "source": "source/crawl.vmd", "track": "base", "loop": true, "root_motion": false},
    "sleep": {"action": "MMD_Sleep", "source": "source/sleep.vmd", "track": "base", "loop": true},
    "lie_down": {"action": "MMD_LieDown", "source": "source/lie_down.vmd", "track": "base"},
    "fall_down": {"action": "MMD_Fall", "source": "source/fall_down.vmd", "track": "base"},
    "swim": {"action": "MMD_Swim", "source": "source/swim.vmd", "track": "base", "loop": true},
    "climb": {"action": "MMD_Climb", "source": "source/climb.vmd", "track": "base", "loop": true},
    "swing_weapon": {"action": "MMD_SwingRight", "source": "source/swing_weapon.vmd", "track": "upper"},
    "walk_fast": {"fallback": "run"},
    "walk_slow": {"fallback": "walk"},
    "sprint": {"fallback": "run"},
    "talk": {"fallback": "idle"},
    "listen": {"fallback": "idle"},
    "wave": {"fallback": "swing_weapon"},
    "point": {"fallback": "swing_weapon"},
    "get_up": {"fallback": "idle"},
    "talk_happy": {"fallback": "talk"},
    "talk_angry": {"fallback": "talk"},
    "talk_sad": {"fallback": "talk"}
  }
}
