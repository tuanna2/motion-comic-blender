{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://motion-comic.local/schemas/series.schema.json",
  "title": "Motion Comic Series Registry",
  "type": "object",
  "required": ["version", "series_id", "language", "story_rules", "narrator", "characters", "locations", "production", "crowd"],
  "properties": {
    "version": {"const": "1.0"},
    "series_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "language": {"type": "string", "minLength": 2},
    "characters": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": false,
      "items": {
        "type": "object",
        "required": ["id", "name", "role", "personality", "visual", "voice_profiles"]
      }
    },
    "relationships": {"type": "array"},
    "story_rules": {"type": "object"},
    "narrator": {"type": "object"},
    "locations": {"type": "array", "minItems": 1},
    "production": {"type": "object"},
    "crowd": {"type": "object"}
  }
}
