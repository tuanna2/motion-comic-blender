{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Episode Plan",
  "type": "object",
  "required": ["version", "title", "scenes"],
  "properties": {
    "version": {"const": "1.0"},
    "title": {"type": "string", "minLength": 1},
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["location_id", "characters", "speech", "visual_beats"],
        "properties": {
          "id": {"type": "string"},
          "location_id": {"type": "string"},
          "characters": {"type": "array"},
          "speech": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["speaker", "text", "narration"],
              "properties": {
                "speaker": {"type": "string", "minLength": 1},
                "listener": {"type": ["string", "null"]},
                "text": {"type": "string", "minLength": 1},
                "narration": {"type": "boolean"},
                "auto_face": {"type": "boolean"},
                "turn_duration": {"type": "number", "exclusiveMinimum": 0},
                "pause_after": {"type": "number", "minimum": 0}
              }
            }
          },
          "visual_beats": {"type": "array"}
        }
      }
    }
  }
}
